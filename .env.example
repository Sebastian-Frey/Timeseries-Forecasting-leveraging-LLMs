# Paper repo environment example.
#
# Copy this file to `.env` at the repo root and fill in the values.
# `.env` is gitignored; never commit real keys.

# Absolute path to the directory that holds the paper's input/output
# artefacts (keyword panels, DTW-neighbour parquet folders, intermediate
# tables). On Colab this is typically the mounted Drive path
# `/content/drive/MyDrive/colab_data/cleaned_cpu`, which is used as the
# default if PAPER_DATA_ROOT is unset.
PAPER_DATA_ROOT=

# Nixtla TimeGPT API key. Required for the `6_LLM_forecasters/timegpt/`
# notebooks. Obtain one at https://nixtla.io .
NIXTLA_API_KEY=

# Hugging Face access token. Required for the `6_LLM_forecasters/moirai/`
# notebooks (to pull the Moirai pretrained weights). Obtain one at
# https://huggingface.co/settings/tokens .
HF_TOKEN=
